# ============================================================
# BuildX — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Django
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# MongoDB Atlas
# Example: mongodb+srv://user:password@cluster.mongodb.net/buildx?retryWrites=true&w=majority
MONGODB_URI=mongodb://mongo:27017/buildx
MONGODB_DB_NAME=buildx

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# OpenRouter LLM API (OpenAI-compatible standard)
# Get your key at: https://openrouter.ai/
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Default LLM Models (via OpenRouter)
LLM_DEFAULT_MODEL=openai/gpt-4o-mini
LLM_PREMIUM_MODEL=anthropic/claude-3.5-sonnet
LLM_FAST_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Embeddings
EMBEDDING_MODEL=openai/text-embedding-3-small

# MCP Servers
MCP_FILESYSTEM_ROOT=/projects
MCP_GITHUB_TOKEN=your-github-token-here

# Frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Celery
CELERY_WORKER_CONCURRENCY=4
